{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "prelude": "build.sh",
        "includeFiles": [
          "bin/ffmpeg",
          "bin/ffprobe",
          "fonts/**"
        ]
      }
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
